{
  "name": "@cortexkit/opencode-magic-context",
  "version": "0.3.3",
  "type": "module",
  "description": "OpenCode plugin for Magic Context — cross-session memory and context management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opencode-magic-context": "dist/cli.js"
  },
  "author": "ualtinok",
  "license": "MIT",
  "keywords": [
    "opencode",
    "plugin",
    "context",
    "memory",
    "ai",
    "llm",
    "prompt-caching",
    "session-history"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cortexkit/opencode-magic-context",
    "directory": "packages/plugin"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --external @huggingface/transformers --external @opencode-ai/plugin && bun build src/cli/index.ts --outfile dist/cli.js --target node --format esm && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@huggingface/transformers": "^3.5.1",
    "@opencode-ai/plugin": "^1.2.26",
    "@opencode-ai/sdk": "^1.2.26",
    "ai-tokenizer": "^1.0.6",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.10",
    "typescript": "^5.8.0",
    "@biomejs/biome": "^2.4.7"
  }
}
